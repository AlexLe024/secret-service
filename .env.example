# ───── Database ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=secret_service
DB_SSLMODE=disable

# ───── Crypto ───────────────────────────────────────────────────────────
# 32-byte AES key encoded as 64 hex characters.
# Generate one with: openssl rand -hex 32
# Losing this key means losing every encrypted secret. Back it up.
AES_KEY_HEX=replace-with-output-of-openssl-rand-hex-32

# ───── Auth ─────────────────────────────────────────────────────────────
# JWT signing secret, minimum 32 characters.
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32

# ───── Server ───────────────────────────────────────────────────────────
ADDR=:8080
LOG_LEVEL=info
MIGRATIONS_DIR=./migrations
